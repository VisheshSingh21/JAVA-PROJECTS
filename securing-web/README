  <!-- HOW IT WORKS -->
  <section>
    <p class="section-label">// flow</p>
    <h2 class="section-title">How It Works</h2>
    <div class="flow">
      <div class="flow-step">
        <div class="flow-left">
          <div class="flow-num">01</div>
          <div class="flow-line"></div>
        </div>
        <div class="flow-content">
          <h3>User visits the home page</h3>
          <p>The root <code>/</code> and <code>/home</code> routes are publicly accessible — no login needed.</p>
          <span class="flow-tag">permitAll()</span>
        </div>
      </div>
      <div class="flow-step">
        <div class="flow-left">
          <div class="flow-num">02</div>
          <div class="flow-line"></div>
        </div>
        <div class="flow-content">
          <h3>Clicks the protected link</h3>
          <p>Clicking "here" attempts to reach <code>/hello</code> which is a secured route.</p>
          <span class="flow-tag">authenticated()</span>
        </div>
      </div>
      <div class="flow-step">
        <div class="flow-left">
          <div class="flow-num">03</div>
          <div class="flow-line"></div>
        </div>
        <div class="flow-content">
          <h3>Redirected to custom login page</h3>
          <p>Spring Security intercepts the request and redirects to <code>/login</code> automatically.</p>
          <span class="flow-tag">SecurityFilterChain</span>
        </div>
      </div>
      <div class="flow-step">
        <div class="flow-left">
          <div class="flow-num">04</div>
          <div class="flow-line"></div>
        </div>
        <div class="flow-content">
          <h3>Enters credentials</h3>
          <p>Username <code>user</code> and password <code>password</code> — verified against the in-memory user store.</p>
          <span class="flow-tag">InMemoryUserDetailsManager</span>
        </div>
      </div>
      <div class="flow-step">
        <div class="flow-left">
          <div class="flow-num">05</div>
          <div class="flow-line"></div>
        </div>
        <div class="flow-content">
          <h3>Lands on bio profile page</h3>
          <p>Authenticated user sees their name and a textarea to write and save their personal bio.</p>
          <span class="flow-tag">ProfileController</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FILE STRUCTURE -->
